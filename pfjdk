SELECT 
    category, 
    COUNT(*) as total_count
FROM (
    SELECT unnest(conv_categories(categories)) as category
    FROM subject
) as t
WHERE category IN (
    'GREY', 
    'BLACK', 
    'DRUG_CEPI_GREY', 
    'DRUG_GREY', 
    'PYRAMID_GREY', 
    'CASINO_GREY', 
    'DROPPER'
)
GROUP BY category
ORDER BY total_count DESC
LIMIT 3;
